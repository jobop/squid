{
  "id": "telegram",
  "name": "Telegram",
  "version": "1.0.0",
  "main": "./extension-entry.ts",
  "configForm": {
    "userConfigFile": "telegram-channel.json",
    "intro": "Configuration is saved to ~/.squid/telegram-channel.json. Saving reloads the extension.",
    "fields": [
      {
        "key": "botToken",
        "label": "Bot Token",
        "type": "password",
        "secret": true,
        "placeholder": "Get from @BotFather"
      },
      {
        "key": "defaultChatId",
        "label": "Default Chat ID",
        "type": "text",
        "optional": true,
        "placeholder": "Used when outbound message has no explicit target"
      },
      {
        "key": "allowedChatIds",
        "label": "Allowed Chat ID list (JSON array)",
        "type": "json",
        "optional": true,
        "placeholder": "[\"123456\", \"-1001234567890\"]"
      },
      {
        "key": "apiBase",
        "label": "API Base URL",
        "type": "text",
        "optional": true,
        "placeholder": "Default: https://api.telegram.org"
      }
    ]
  }
}
