{
  "id": "feishu",
  "name": "Feishu / Lark",
  "version": "1.0.0",
  "main": "./extension-entry.ts",
  "configForm": {
    "userConfigFile": "feishu-channel.json",
    "intro": "Saved to ~/.squid/feishu-channel.json. Sensitive fields are not echoed in UI; leave empty to keep unchanged. Saving reloads the extension.",
    "fields": [
      {
        "key": "appId",
        "label": "App ID",
        "type": "text",
        "placeholder": "cli_xxx"
      },
      {
        "key": "appSecret",
        "label": "App Secret",
        "type": "password",
        "secret": true,
        "placeholder": "Leave empty to keep unchanged"
      },
      {
        "key": "encryptKey",
        "label": "Encrypt Key (event subscription)",
        "type": "password",
        "secret": true,
        "optional": true,
        "placeholder": "Leave empty to keep unchanged"
      },
      {
        "key": "verificationToken",
        "label": "Verification Token",
        "type": "password",
        "secret": true,
        "optional": true,
        "placeholder": "Optional; leave empty to keep unchanged"
      },
      {
        "key": "connectionMode",
        "label": "Connection mode",
        "type": "select",
        "options": [
          { "value": "websocket", "label": "websocket (long connection)" },
          { "value": "webhook", "label": "webhook" }
        ]
      },
      {
        "key": "feishuDomain",
        "label": "Domain",
        "type": "select",
        "options": [
          { "value": "feishu", "label": "feishu (mainland China)" },
          { "value": "lark", "label": "lark (international)" }
        ]
      },
      {
        "key": "defaultReceiveId",
        "label": "Default receiver ID (outbound)",
        "type": "text",
        "secret": true,
        "optional": true,
        "placeholder": "Group chat_id etc.; hidden when configured, re-enter to update"
      },
      {
        "key": "defaultReceiveIdType",
        "label": "Receiver ID type",
        "type": "select",
        "options": [
          { "value": "chat_id", "label": "chat_id" },
          { "value": "open_id", "label": "open_id" },
          { "value": "user_id", "label": "user_id" },
          { "value": "union_id", "label": "union_id" }
        ]
      }
    ]
  }
}
